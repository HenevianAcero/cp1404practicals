BoxLayout:
    orientation: 'horizontal'
    TextInput:
        id: input_miles
        text: ''
    BoxLayout:
        orientation: 'vertical'
        size_hint_x: 0.25
        Button:
            text: 'Up'
            on_press: app.handle_increment(1)
        Button:
            text: 'Down'
            on_press: app.handle_increment(-1)
BoxLayout:
    orientation: 'vertical'
    Button:
        text: 'Convert from miles to km'
        on_press: app.handle_convert()
    Label:
        id: output_km
        color: (1,1,0,0)

